<div class="flex items-center justify-center min-h-screen bg-gray-100">
  <div class="w-full max-w-md bg-white p-8 rounded-lg shadow-md">
    <h1 class="text-2xl font-bold text-gray-800 text-center mb-6">Forgot your password?</h1>

    <%= tag.div(flash[:alert], class: "mb-4 p-3 text-red-700 bg-red-100 border border-red-400 rounded-lg") if flash[:alert] %>

    <%= form_with url: passwords_path, class: "space-y-4" do |form| %>
      <div>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "Enter your email address", value: params[:email_address], class: "mt-1 w-full px-4 py-2 border rounded-lg focus:ring focus:ring-blue-300" %>
      </div>
      <div class="mt-4">
        <%= form.submit "Email reset instructions", class: "w-full px-4 py-2 bg-blue-500 text-white font-semibold rounded-lg hover:bg-blue-600 transition" %>
      </div>
    <% end %>
  </div>
</div>