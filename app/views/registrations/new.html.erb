<div class="flex items-center justify-center min-h-screen bg-gray-100">
  <div class="w-full max-w-md bg-white p-8 rounded-lg shadow-md">
    <h1 class="text-2xl font-bold text-gray-800 text-center mb-6">Registrar</h1>

    <turbo-frame id="flash">
      <%= tag.div(flash[:alert], class: "mb-4 p-3 text-red-700 bg-red-100 border border-red-400 rounded-lg") if flash[:alert] %>
      <%= tag.div(flash[:notice], class: "mb-4 p-3 text-green-700 bg-green-100 border border-green-400 rounded-lg") if flash[:notice] %>
    </turbo-frame>

    <%= form_with model: @user, url: registration_path, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :email_address, class: "block text-gray-700 font-medium" %>
        <%= form.email_field :email_address, required: true, class: "mt-1 w-full px-4 py-2 border rounded-lg focus:ring focus:ring-blue-300" %>
      </div>

      <div>
        <%= form.label :password, class: "block text-gray-700 font-medium" %>
        <%= form.password_field :password, required: true, class: "mt-1 w-full px-4 py-2 border rounded-lg focus:ring focus:ring-blue-300" %>
      </div>

      <div>
        <%= form.label :password_confirmation, class: "block text-gray-700 font-medium" %>
        <%= form.password_field :password_confirmation, required: true, class: "mt-1 w-full px-4 py-2 border rounded-lg focus:ring focus:ring-blue-300" %>
      </div>

      <div class="mt-4">
        <%= form.submit "Registrar", class: "w-full px-4 py-2 bg-blue-500 text-white font-semibold rounded-lg hover:bg-blue-600 transition" %>
      </div>
    <% end %>
  </div>
</div>

